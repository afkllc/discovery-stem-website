---
// src/components/Logo.astro (simple — avoids absolute positioning)
import config from "@/config/config.json";
import ImageMod from "./ImageMod.astro";

const {
  src,
  srcDarkmode,
  ratio = "3/1",    // change to whatever ratio you want e.g. "4/1"
  width = "150px",  // visual width of the logo box
  cover = false,    // keeps object-contain by default
  class: extra = "",
} = Astro.props as {
  src?: string;
  srcDarkmode?: string;
  ratio?: string;
  width?: string;
  cover?: boolean;
  class?: string;
};

const { logo, logo_darkmode, logo_text, title } = config.site;
const { theme_switcher } = config.settings;

// numeric sizes for ImageMod (keeps srcset sharp)
const widthNum = parseInt(String(width).replace(/[^0-9]/g, ""), 10) || 100;
const [rw, rh] = String(ratio).split("/").map((n) => parseFloat(n) || 1);
const ratioNum = (rw && rh) ? rw / rh : 3 / 1;
const heightNum = Math.round(widthNum / ratioNum);
const fitClass = cover ? "object-cover" : "object-contain";
---

<a href="/" class={`navbar-brand inline-flex items-center ${extra}`} aria-label={title}>
  {
    src || srcDarkmode || logo || logo_darkmode ? (
      <div
  class="logo-box flex items-center justify-center overflow-visible"
  style={`width:${width}; aspect-ratio:${ratio}; line-height:0;`}
>
  <img
    src={src ? src : logo}
    alt={title}
    class={`block w-full h-full object-contain ${theme_switcher ? "dark:hidden" : ""}`}
  />

  {theme_switcher && (
    <img
      src={srcDarkmode ? srcDarkmode : logo_darkmode}
      alt={title}
      class="hidden dark:block w-full h-full object-contain"
    />
  )}
</div>
    ) : logo_text ? (
      <span style={`width:${width}; aspect-ratio:${ratio}; display:inline-flex; align-items:center; justify-content:center;`} class="inline-flex">
        {logo_text}
      </span>
    ) : (
      <span style={`width:${width}; aspect-ratio:${ratio}; display:inline-flex; align-items:center; justify-content:center;`} class="inline-flex">
        {title}
      </span>
    )
  }
</a>