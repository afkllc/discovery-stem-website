---
import type { Event } from "../../types/eventCollection";

interface Props {
  events: Event[];
}

const { events } = Astro.props as Props;

const count = events.length;

// Dynamically control grid layout
let gridClasses = "events-grid grid gap-6";

if (count === 1) {
  gridClasses += " grid-cols-1 justify-items-center";
} else if (count === 2) {
  gridClasses += " grid-cols-1 md:grid-cols-2 justify-items-center";
} else {
  gridClasses += " grid-cols-1 md:grid-cols-2 lg:grid-cols-3";
}
---

<div class={gridClasses}>
  {count > 0 ? (
    events.map((event) => (
      /* Make the entire card a link — card-level classes here */
      <a
        href={`/events/${event.id}`}
        class="group block w-full max-w-sm mx-auto bg-white dark:bg-gray-800 rounded-lg shadow transition-transform transform hover:scale-105 hover:shadow-lg focus:outline-none focus-visible:ring-2 focus-visible:ring-primary overflow-visible"
        aria-label={`${event.title} — View event`}
      >
        <img
          src={event.image}
          alt={event.title}
          class="w-full h-40 object-cover"
        />
        <div class="p-4">
          <div class="flex justify-between items-start mb-2">
            <span class="text-sm font-semibold text-secondary dark:text-white/60  capitalize">
              {event.category}
            </span>
            <span class="text-sm text-secondary/80 dark:text-white/80">
              {new Date(event.date).toLocaleDateString("en-US", { month: "short", day: "numeric" })}
            </span>
          </div>
          <h3 class="text-lg font-bold text-secondary dark:text-white mb-1">
            {event.title}
          </h3>
          <p class="text-secondary/80 dark:text-white/80 text-sm mb-3">
            {event.description}
          </p>

          {/* removed the inner "Learn More" anchor because the whole card is clickable */}
        </div>
      </a>
    ))
  ) : (
    <div class="col-span-full text-center py-12">
      <p class="text-gray-600 dark:text-gray-400 text-lg">
        No events found. Check back soon!
      </p>
    </div>
  )}
</div>